---
import { getCollection } from "astro:content"
import ApiReferencePage from "~/components/ApiReferencePage.astro"

const entries = await getCollection("ccip")

const entry = entries.find((e) => {
  const normalized = e.id.replace(/\\/g, "/")
  return normalized === "api-reference/evm/v160/pool"
})

if (!entry) {
  throw new Error("Entry not found: api-reference/evm/v160/pool")
}
---

<ApiReferencePage {entry} />
