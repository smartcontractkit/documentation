---
import { getCollection } from "astro:content"
import ApiReferencePage from "~/components/ApiReferencePage.astro"

const entries = await getCollection("chainlink-local")

const entry = entries.find((e) => {
  const normalized = e.id.replace(/\\/g, "/")
  return normalized === "api-reference/v022/aggregator-v2-v3-interface"
})

if (!entry) {
  throw new Error("Entry not found: api-reference/v022/aggregator-v2-v3-interface")
}
---

<ApiReferencePage {entry} />
