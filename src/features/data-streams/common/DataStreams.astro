---
import GettingStartedComponent from "./gettingStarted.mdx"
import GettingStartedHardhatComponent from "./gettingStartedHardhat.mdx"
import AsideDisclaimerComponent from "./asideDisclaimer.mdx"
import DsNotesComponent from "./dsNotes.mdx"
import StreamsLookupErrorHandlerComponent from "./streamsLookupErrorHandler.mdx"
import StreamsTradeDeprecationComponent from "./streamsTradeDeprecation.mdx"

export type Props = {
  section?:
    | "gettingStarted"
    | "gettingStartedHardhat"
    | "asideDisclaimer"
    | "dsNotes"
    | "streamsLookupErrorHandler"
    | "streamsTradeDeprecation"
}
const { section } = Astro.props as Props
---

{section === "gettingStarted" && <GettingStartedComponent />}
{section === "gettingStartedHardhat" && <GettingStartedHardhatComponent />}
{section === "asideDisclaimer" && <AsideDisclaimerComponent />}
{section === "dsNotes" && <DsNotesComponent />}
{section === "streamsLookupErrorHandler" && <StreamsLookupErrorHandlerComponent />}
{section === "streamsTradeDeprecation" && <StreamsTradeDeprecationComponent />}
