---
import CcipDirectoryLayout from "~/layouts/CcipDirectoryLayout.astro"
import { getEntry, render } from "astro:content"
import {
  Environment,
  DecommissionedNetwork,
  getAllDecommissionedNetworks,
  getAllNetworks,
  getDecommissionedNetworkWithDetails,
  getSearchLanes,
  Network,
} from "~/config/data/ccip"
import ChainHero from "~/components/CCIP/ChainHero/ChainHero"
import { generateDecommissionedChainStructuredData } from "~/utils/ccipStructuredData"
import StructuredData from "~/components/StructuredData.astro"

interface Props {
  environment: Environment
  network: DecommissionedNetwork
}
const { environment, network } = Astro.props as Props

const entry = await getEntry("ccip", "index")
if (!entry) {
  throw new Error('Could not find "ccip/index" doc. Check src/content/ccip/index.mdx!')
}

const { headings } = await render(entry)

const networkDetails = getDecommissionedNetworkWithDetails({ chain: network.chain, filter: environment })
const heroNetwork: Network = networkDetails ?? {
  name: network.name,
  chain: network.chain,
  chainSelector: network.chainSelector,
  logo: network.logo,
  explorer: network.explorer,
  chainType: network.chainType,
  key: network.chain,
  totalLanes: 0,
  totalTokens: 0,
  armProxy: {
    address: "",
    version: "",
  },
}

const activeNetworks = getAllNetworks({ filter: environment })
const decommissionedNetworks = getAllDecommissionedNetworks({ filter: environment })
const searchChains = [
  ...activeNetworks.map(({ name, totalLanes, totalTokens, logo, chain }) => ({
    name,
    totalLanes,
    totalTokens,
    logo,
    chain,
  })),
  ...decommissionedNetworks.map(({ name, logo, chain }) => ({
    name,
    totalLanes: 0,
    totalTokens: 0,
    logo,
    chain,
  })),
]
const searchLanes = getSearchLanes({ environment })

const environmentText = environment === Environment.Mainnet ? "Mainnet" : "Testnet"
const chainMetadata = {
  title: `${network.name} CCIP Network (Inactive) - ${environmentText}`,
  description: `Inactive CCIP network for ${network.name} on ${environmentText}. This chain is no longer active but historical transaction data remains accessible via CCIP Explorer.`,
  image: network.logo,
  excerpt: `${network.name} inactive CCIP network ${environmentText.toLowerCase()} historical data chain selector ${network.chainSelector} blockchain interoperability`,
}

const currentURL = new URL(Astro.request.url).href
const decommissionedChainStructuredData = generateDecommissionedChainStructuredData(network, environment, currentURL)
---

<CcipDirectoryLayout
  frontmatter={{
    title: chainMetadata.title,
    section: "ccip",
    metadata: {
      description: chainMetadata.description,
      image: chainMetadata.image,
      excerpt: chainMetadata.excerpt,
    },
  }}
  {headings}
  environment={environment}
>
  <StructuredData data={decommissionedChainStructuredData} />
  <ChainHero
    chains={searchChains}
    tokens={[]}
    network={heroNetwork}
    environment={environment}
    lanes={searchLanes}
    isDecommissioned={true}
    client:load
  />
  <section class="layout">
    <div class="decom-content">
      <h2>About Inactive Chains</h2>
      <div class="decom-info-grid">
        <div class="decom-info-item">
          <h3>🚫 No New Transactions</h3>
          <p>You cannot initiate new CCIP transactions from or to this chain.</p>
        </div>
        <div class="decom-info-item">
          <h3>📊 Historical Data Available</h3>
          <p>Past transactions remain accessible through the CCIP Explorer using:</p>
          <ul>
            <li><strong>Message ID</strong> or <strong>Transaction Hash</strong></li>
            <li>
              <strong>Addresses:</strong> Origin (transaction initiator), From (CCIP Router caller), or To (destination receiver)
            </li>
          </ul>
        </div>
        <div class="decom-info-item">
          <h3>🔧 Contract Updates Required</h3>
          <p>Developers should remove this chain selector from their token pool configurations.</p>
        </div>
      </div>
    </div>
  </section>
</CcipDirectoryLayout>

<style scoped="false">
  .layout {
    --gutter: var(--space-10x);
    --doc-padding: var(--space-4x);
    margin: var(--space-8x) auto;
    display: flex;
    flex-direction: column;
    gap: var(--gutter);
    padding: var(--doc-padding);
  }

  .decom-content {
    max-width: 800px;
    margin: 0 auto;
    width: 100%;
  }

  .decom-content h2 {
    color: var(--gray-900);
    font-size: 22px;
    line-height: var(--space-10x);
    margin: 0 0 var(--space-6x) 0;
    text-align: center;
  }

  .decom-info-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6x);
  }

  .decom-info-item {
    padding: var(--space-6x);
    background: var(--color-background-secondary);
    border-radius: var(--border-radius-10);
    border: 1px solid var(--gray-200);
  }

  .decom-info-item h3 {
    font-size: 18px;
    font-weight: 600;
    color: var(--gray-900);
    margin: 0 0 var(--space-3x) 0;
    text-align: center;
  }

  .decom-info-item p {
    color: var(--gray-600);
    margin: 0;
    line-height: 1.6;
    text-align: left;
  }

  .decom-info-item ul {
    color: var(--gray-600);
    margin: var(--space-3x) 0 0 0;
    padding-left: var(--space-5x);
    line-height: 1.6;
    text-align: left;
    list-style-type: disc;
    list-style-position: outside;
  }

  .decom-info-item li {
    margin-bottom: var(--space-2x);
    text-align: left;
  }

  .decom-info-item li strong {
    color: var(--gray-900);
  }

  @media (min-width: 40em) {
    .decom-info-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 50em) {
    .layout {
      max-width: 1500px;
      padding: 0 var(--space-6x);
    }

    .decom-info-grid {
      grid-template-columns: 1fr 1fr 1fr;
    }
  }

  @media (min-width: 992px) {
    .layout {
      padding: var(--space-10x) var(--space-8x);
    }

    .decom-content {
      max-width: none;
    }
  }
</style>
